{% extends "_base.html.j2" %}

{% block title %}KOUBO WATCH — アーカイブ{% endblock %}

{% block extra_style %}
<style>
  .archive-header {
    margin-bottom: 1.5rem;
  }
  .archive-header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent);
    border-bottom: 2px solid var(--accent);
    padding-bottom: .35rem;
    margin-bottom: .5rem;
  }
  .archive-header .stats-bar {
    font-size: .85rem;
    color: var(--muted);
  }

  /* --- Month group --- */
  .month-group {
    margin-bottom: 2.5rem;
  }
  .month-group summary.month-header {
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent);
    border-bottom: 1px solid var(--rule);
    padding: .35rem .2rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: .5rem;
    user-select: none;
  }
  .month-group summary.month-header::before {
    content: "▸";
    transition: transform .2s;
    display: inline-block;
  }
  .month-group[open] summary.month-header::before {
    transform: rotate(90deg);
  }

  /* --- Archive table --- */
  .archive-table-wrap {
    overflow-x: auto;
    margin-top: .75rem;
  }
  .archive-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .875rem;
  }
  .archive-table th {
    text-align: left;
    padding: .45rem .6rem;
    border-bottom: 2px solid var(--accent);
    color: var(--accent);
    font-weight: 600;
    white-space: nowrap;
  }
  .archive-table td {
    padding: .4rem .6rem;
    border-bottom: 1px solid var(--card-border);
    vertical-align: top;
  }
  .archive-table tr:hover td {
    background: #f0ebe0;
  }
  .archive-table td.title-cell {
    max-width: 380px;
  }
  .archive-table td.title-cell a {
    color: var(--accent);
    text-decoration: none;
    /* clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .archive-table td.title-cell a:hover {
    text-decoration: underline;
  }
  .archive-table td.score-cell {
    text-align: center;
    white-space: nowrap;
  }
  .archive-table td.source-cell {
    white-space: nowrap;
    color: var(--muted);
    font-size: .8rem;
  }
  .archive-table td.date-cell {
    white-space: nowrap;
  }
  .archive-table td.cat-cell {
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .archive-table th,
    .archive-table td { padding: .3rem .4rem; font-size: .8rem; }
  }
</style>
{% endblock %}

{% block content %}
<div class="archive-header">
  <h2>全件アーカイブ</h2>
  <div class="stats-bar">全 {{ total_count }} 件 | 生成: {{ generated_at }}</div>
</div>

{% if not month_groups %}
<div class="empty">案件データがありません。</div>
{% else %}

{% for month_label, tenders in month_groups %}
<details class="month-group" open>
  <summary class="month-header">{{ month_label }}（{{ tenders | length }} 件）</summary>
  <div class="archive-table-wrap">
    <table class="archive-table">
      <thead>
        <tr>
          <th>タイトル</th>
          <th>カテゴリ</th>
          <th>期限</th>
          <th>スコア</th>
          <th>ソース</th>
        </tr>
      </thead>
      <tbody>
        {% for t in tenders %}
        <tr>
          <td class="title-cell">
            <a href="{{ t.url }}" target="_blank" rel="noopener noreferrer">{{ t.title }}</a>
          </td>
          <td class="cat-cell">
            {% if t.category_nuclear %}<span class="badge badge-cat">原子力</span> {% endif %}
            {% if t.category_radiation %}<span class="badge badge-cat">放射線</span> {% endif %}
            {% if t.category_grid %}<span class="badge badge-cat">送配電</span> {% endif %}
          </td>
          <td class="date-cell">
            {% if t.deadline %}{{ t.deadline.strftime("%Y-%m-%d") }}{% else %}—{% endif %}
          </td>
          <td class="score-cell">
            {% if t.energy_system_score is not none %}
              {% if t.energy_system_score >= 8 %}
                <span class="badge badge-score-high">{{ t.energy_system_score }}</span>
              {% elif t.energy_system_score >= 5 %}
                <span class="badge badge-score-mid">{{ t.energy_system_score }}</span>
              {% else %}
                <span class="badge badge-score-low">{{ t.energy_system_score }}</span>
              {% endif %}
            {% else %}
              <span style="color:var(--muted)">—</span>
            {% endif %}
          </td>
          <td class="source-cell">{{ t.source }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</details>
{% endfor %}

{% endif %}
{% endblock %}

{% block generated_at %}{{ generated_at }}{% endblock %}
